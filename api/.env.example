# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/buymeacoffee_eth"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TTL_DAYS=30
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
FINANCIAL_ACCOUNT_ENCRYPTION_KEY=replace-with-a-strong-random-secret

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ─── Chapa Payment Gateway ────────────────────────────────────────────────────
CHAPA_SECRET_KEY=CHASECK_TEST-your-chapa-secret-key
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret

# ─── Dev only ─────────────────────────────────────────────────────────────────
EXPOSE_RESET_TOKEN=false
